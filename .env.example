SERVER_PORT=:3000
GIN_MODE=release
REQUEST_TIMEOUT=30s

POSTGRES=postgres://user:password@127.0.0.1:5432/app?sslmode=disable
GORM_LOG_LEVEL=warn
DB_MAX_IDLE_CONNS=15
DB_MAX_OPEN_CONNS=30
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=5m

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_CACHE_DB=0
REDIS_QUEUE_DB=6

JWT_SECRET=change-me-in-production
JWT_ISSUER=go-skeleton
JWT_TTL=24h

LOG_LEVEL=info
LOG_FORMAT=json
LOG_STACKTRACE_LEVEL=error
AUDIT_LOG_ENABLED=true
AUDIT_LOG_EXCLUDE_PATHS=/health

# Comma-separated browser origins. Empty means no CORS allow headers.
CORS_ALLOW_ORIGINS=
RATE_LIMIT_PER_MINUTE=0
