#!/usr/bin/env bash
#
# go-skeleton pre-commit hook
#
# 启用方式（一次性，每个 clone 都要做）：
#   git config core.hooksPath .githooks
#
# 关掉方式：
#   git config --unset core.hooksPath
#
# 做的事：跑轻量级检查，给出 fail-fast 反馈；不跑全量 make verify
# （那个太慢，留到 push 前手动跑 / CI 兜底）。这里只做：
#   1. fmt + vet                              — 30s 内能给出回应
#   2. 阻止疑似秘钥 / .env 真值被加进暂存
#   3. 不允许 git add --no-verify 跳过 hook
#
# 如果想跑全量校验，前面 export FULL=1：FULL=1 git commit ...

set -euo pipefail

# 只看本次提交动到的 *.go，全部都跑没必要。
staged_go=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.go$' || true)

# ---- 1. fmt + vet（仅在改了 .go 时跑）----
if [ -n "$staged_go" ]; then
  echo "[pre-commit] fmt + vet ..."
  if ! make --no-print-directory fmt vet; then
    echo "[pre-commit] fmt/vet failed. Fix the issues and re-add files."
    exit 1
  fi
fi

# ---- 2. 秘钥 / .env 真值兜底 ----
staged_all=$(git diff --cached --name-only --diff-filter=ACMR || true)

deny_patterns=(
  '\.env$'
  '\.env\.[a-zA-Z0-9_-]+$'
  'cmd/[^/]+/\.env$'
  'credentials\.json$'
  '\.pem$'
  'id_rsa$'
)

violations=()
for f in $staged_all; do
  for pat in "${deny_patterns[@]}"; do
    if [[ "$f" =~ $pat ]]; then
      # .env.example 例外（白名单）。
      if [[ "$f" == ".env.example" ]]; then
        continue
      fi
      violations+=("$f")
    fi
  done
done

if [ ${#violations[@]} -gt 0 ]; then
  echo "[pre-commit] refusing to commit potentially sensitive files:"
  printf '  - %s\n' "${violations[@]}"
  echo "         如果确认要提交，跑 git commit --no-verify （慎用，并自负责任）。"
  exit 1
fi

# ---- 3. FULL=1 时跑全量 verify ----
if [ "${FULL:-0}" = "1" ]; then
  echo "[pre-commit] FULL=1, running make verify ..."
  make --no-print-directory verify
fi

echo "[pre-commit] ok."
